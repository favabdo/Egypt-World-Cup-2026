FOOTBALL_DATA_API_KEY="fd7545d5dbeb424e90ccebf137b0515e"

# Groq (https://console.groq.com) — powers per-player tournament stats,
# per-match stats, lineups, and substitutions via Groq's "compound" system,
# which has a built-in web_search tool. Get a key from
# https://console.groq.com/keys (NOT groq.com's chat product, and NOT
# xAI/Grok — Groq the inference company and Grok/xAI are different products
# with confusingly similar names).
GROQ_API_KEY=""
# Optional: overrides the default model ("groq/compound").
GROQ_MODEL="groq/compound"
